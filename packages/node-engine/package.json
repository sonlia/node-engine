{
  "name": "@sonlia/node-engine",
  "version": "0.2.1",
  "description": "A modernized refactor of litegraph.js — ES6 modules, engine/UI separation, 5-strategy execution optimization, node/slot visibility, Web Worker support.",
  "main": "dist/node-engine.cjs.js",
  "module": "dist/node-engine.esm.js",
  "browser": "dist/node-engine.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/node-engine.umd.js",
      "import": "./dist/node-engine.esm.js",
      "require": "./dist/node-engine.cjs.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {},
  "keywords": [
    "litegraph",
    "node-graph",
    "visual-programming",
    "node-editor",
    "graph-editor",
    "canvas"
  ],
  "author": "sonlia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sonlia/node-engine.git"
  },
  "bugs": {
    "url": "https://github.com/sonlia/node-engine/issues"
  },
  "homepage": "https://github.com/sonlia/node-engine#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "esbuild": "^0.28.1"
  }
}
